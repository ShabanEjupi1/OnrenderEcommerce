@model ProjectTemplate.Models.Ecommerce.ProductDetailViewModel
@{
    var p = Model.Product;
    ViewData["Title"] = p.Name;
    ViewData["Description"] = p.Description ?? $"{p.Name} – {p.CategoryName} në Enisi Center. Çmimi: {p.DisplayPrice:F2}€";
}

<div class="product-detail-page">
    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="breadcrumb">
        <a asp-controller="Home" asp-action="Index">Ballina</a>
        <span>›</span>
        <a asp-controller="Shop" asp-action="Index">Dyqani</a>
        @if (!string.IsNullOrEmpty(p.CategoryName))
        {
            <span>›</span>
            <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="@p.CategoryId">@p.CategoryName</a>
        }
        <span>›</span>
        <span>@p.Name</span>
    </nav>

    <div class="detail-layout">
        <!-- Product Image -->
        <div class="detail-image-col">
            <div class="detail-img-wrap">
                <img src="@(p.ImageUrl ?? "/img/placeholder.png")" alt="@p.Name" class="detail-main-img" id="mainImg" />
                @if (p.IsOnSale)
                {
                    <span class="badge-sale badge-lg">-@p.DiscountPercent%</span>
                }
            </div>
        </div>

        <!-- Product Info -->
        <div class="detail-info-col">
            @if (!string.IsNullOrEmpty(p.Brand))
            {
                <p class="detail-brand">@p.Brand</p>
            }
            <h1 class="detail-title">@p.Name</h1>

            @if (!string.IsNullOrEmpty(p.CategoryName))
            {
                <div class="detail-meta">
                    <span class="meta-tag">📁 @p.CategoryName</span>
                    @if (!string.IsNullOrEmpty(p.Unit))
                    {
                        <span class="meta-tag">⚖️ @p.Unit</span>
                    }
                    @if (p.InStock)
                    {
                        <span class="meta-tag in-stock">? Në stok</span>
                    }
                    else
                    {
                        <span class="meta-tag out-stock">? Jo në stok</span>
                    }
                </div>
            }

            <!-- Price -->
            <div class="detail-price-block">
                <span class="detail-price">@p.DisplayPrice.ToString("F2") €</span>
                @if (p.IsOnSale)
                {
                    <span class="detail-old-price">@p.Price.ToString("F2") €</span>
                    <span class="detail-save-badge">Kurseni @(p.Price - p.DisplayPrice):F2 €</span>
                }
            </div>

            <!-- Description -->
            @if (!string.IsNullOrEmpty(p.Description))
            {
                <div class="detail-description">
                    <p>@p.Description</p>
                </div>
            }

            <!-- Add to Cart -->
            @if (p.InStock)
            {
                <div class="detail-add-to-cart">
                    <div class="quantity-control">
                        <button class="qty-btn" onclick="changeQty(-1)">-</button>
                        <input type="number" id="detailQty" value="1" min="1" max="99" class="qty-input" />
                        <button class="qty-btn" onclick="changeQty(1)">+</button>
                    </div>
                    <button class="btn-add-cart-lg" id="addToCartBtn" onclick="addToCartDetail(@p.Id)">
                        🛒 Shto në Shportë
                    </button>
                </div>
            }
            else
            {
                <div class="out-of-stock-notice">
                    <p>❌ Ky produkt nuk është i disponueshëm momentalisht.</p>
                </div>
            }

            <!-- Trust badges -->
            <div class="trust-badges">
                <div class="trust-badge">🚚 Dorëzim falas mbi 50€</div>
                <div class="trust-badge">🔄 Kthim brenda 30 ditëve</div>
                <div class="trust-badge">🔒 Pagim i sigurt</div>
            </div>

            <!-- Share -->
            <div class="detail-share">
                <span>Shpërnda:</span>
                <a href="https://www.facebook.com/sharer/sharer.php?u=@(Context.Request.Scheme)://@(Context.Request.Host)@(Context.Request.Path)" target="_blank" class="share-link">Facebook</a>
                <a href="https://wa.me/?text=@Uri.EscapeDataString(p.Name + " – " + p.DisplayPrice.ToString("F2") + "€")" target="_blank" class="share-link">WhatsApp</a>
            </div>
        </div>
    </div>

    <!-- Related Products -->
    @if (Model.RelatedProducts.Any())
    {
        <section class="related-products">
            <h2>Produkte të ngjashme</h2>
            <div class="product-grid">
                @foreach (var rp in Model.RelatedProducts)
                {
                    <div class="product-card">
                        <a asp-controller="Shop" asp-action="Detail" asp-route-id="@rp.Id" class="product-card-link">
                            <div class="product-img-wrap">
                                <img src="@(rp.ImageUrl ?? "/img/placeholder.png")" alt="@rp.Name" class="product-img" loading="lazy" />
                                @if (rp.IsOnSale) { <span class="badge-sale">-@rp.DiscountPercent%</span> }
                            </div>
                            <div class="product-info">
                                <h3 class="product-name">@rp.Name</h3>
                                <div class="product-price-row">
                                    <span class="product-price">@rp.DisplayPrice.ToString("F2") €</span>
                                    @if (rp.IsOnSale) { <span class="product-old-price">@rp.Price.ToString("F2") €</span> }
                                </div>
                            </div>
                        </a>
                        <button class="btn-add-cart" onclick="addToCart(@rp.Id, this)">+ Shporta</button>
                    </div>
                }
            </div>
        </section>
    }
</div>

@section Scripts {
<script>
function changeQty(delta) {
    const input = document.getElementById('detailQty');
    const val = parseInt(input.value) + delta;
    input.value = Math.max(1, Math.min(99, val));
}

async function addToCartDetail(productId) {
    const qty = parseInt(document.getElementById('detailQty').value) || 1;
    const btn = document.getElementById('addToCartBtn');
    btn.textContent = 'Duke shtuar...';
    btn.disabled = true;
    try {
        const resp = await fetch('/Cart/Add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ productId, quantity: qty })
        });
        const data = await resp.json();
        if (data.success) {
            btn.textContent = '? Shtuar!';
            btn.classList.add('success');
            updateCartBadge(data.cartCount);
            setTimeout(() => {
                btn.textContent = '🛒 Shto në Shportë';
                btn.classList.remove('success');
                btn.disabled = false;
            }, 2000);
        }
    } catch {
        btn.textContent = '🛒 Shto në Shportë';
        btn.disabled = false;
    }
}
</script>
}
