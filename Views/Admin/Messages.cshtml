@{
    ViewData["Title"] = "Mesazhet nga Klientët";
}

<div class="amz-card">
    <div style="display: flex; justify-content: space-between; margin-bottom: 20px; align-items: center;">
        <h3 style="margin:0">Kutia Hyrëse (Inbox)</h3>
        <div>
            <select style="padding: 8px; border: 1px solid #d5d9d9; border-radius: 4px; outline: none;">
                <option>Të gjitha mesazhet</option>
                <option>Të palexuara</option>
                <option>Të rëndësishme</option>
            </select>
        </div>
    </div>

    <div style="border: 1px solid #d5d9d9; border-radius: 6px; overflow: hidden;">
        <div style="display:flex; padding: 15px; border-bottom: 1px solid #d5d9d9; background: #f8f9fa; cursor: pointer;">
            <div style="width: 200px; font-weight: 600; display:flex; align-items: center; gap: 10px;">
                <div style="width:8px; height:8px; background: #007185; border-radius: 50%;"></div>
                Arben Haliti
            </div>
            <div style="flex:1;"><strong>Pyetje rreth porosisë #10025</strong> <span style="color:#666;">- Përshëndetje, desha të di kur do të arrijë porosia ime...</span></div>
            <div style="color: #666; font-size: 0.9rem;">Sot, 14:30</div>
        </div>
        <div style="display:flex; padding: 15px; border-bottom: 1px solid #d5d9d9; cursor: pointer;">
            <div style="width: 200px; font-weight: 500; display:flex; align-items: center; gap: 10px; padding-left: 18px;">
                Fisnik Rexhepi
            </div>
            <div style="flex:1;"><strong>Pjesë për kompjuter</strong> <span style="color:#666;">- A keni në stok kartela grafike RTX 4070 ti?</span></div>
            <div style="color: #666; font-size: 0.9rem;">Dje</div>
        </div>
        <div style="display:flex; padding: 15px; cursor: pointer;">
            <div style="width: 200px; font-weight: 500; display:flex; align-items: center; gap: 10px; padding-left: 18px;">
                Luan Gashi
            </div>
            <div style="flex:1;"><strong>Ankesë për paketimin</strong> <span style="color:#666;">- Paketa e fundit që pranova kishte një gërvishtje në kuti...</span></div>
            <div style="color: #666; font-size: 0.9rem;">24 Prill</div>
        </div>
    </div>
</div>
