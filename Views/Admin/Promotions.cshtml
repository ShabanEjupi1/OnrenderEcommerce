@{
    ViewData["Title"] = "Promovime — Admin";
    var products = ViewBag.Products as List<ProjectTemplate.Models.Ecommerce.Product> ?? new();
    var categories = ViewBag.Categories as List<ProjectTemplate.Models.Ecommerce.ProductCategory> ?? new();
    var subscriberCount = (int)(ViewBag.SubscriberCount ?? 0);
    var emailConfigured = (bool)(ViewBag.EmailConfigured ?? false);
}

<div class="admin-page">

    @if (TempData["Success"] != null) { <div class="alert-success">✅ @TempData["Success"]</div> }
    @if (TempData["Error"] != null) { <div class="alert-error">❌ @TempData["Error"]</div> }

    <!-- Stats Strip -->
    <div class="promo-stats-row">
        <div class="promo-stat">
            <span class="promo-stat-icon">💰</span>
            <div>
                <strong>@products.Count(p => p.IsOnSale)</strong>
                <span>Produkte me Zbritje</span>
            </div>
        </div>
        <div class="promo-stat">
            <span class="promo-stat-icon">⭐</span>
            <div>
                <strong>@products.Count(p => p.IsFeatured)</strong>
                <span>Produkte Featured</span>
            </div>
        </div>
        <div class="promo-stat">
            <span class="promo-stat-icon">🔥</span>
            <div>
                <strong>@products.Count(p => p.IsMostSold)</strong>
                <span>Produkte Bestseller</span>
            </div>
        </div>
        <div class="promo-stat">
            <span class="promo-stat-icon">📧</span>
            <div>
                <strong>@subscriberCount</strong>
                <span>Abonentë Aktivë</span>
            </div>
        </div>
    </div>

    <!-- Bulk Actions Panel -->
    <div class="promo-panel">
        <div class="promo-panel-header">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/>
                <line x1="7" y1="7" x2="7.01" y2="7"/>
            </svg>
            <h3>Veprime Masive</h3>
        </div>

        <div class="promo-actions-grid">
            <!-- Bulk Discount -->
            <div class="promo-action-card">
                <h4>📉 Apliko Zbritje në Produkte</h4>
                <p>Shënoni produktet nga tabela dhe aplikoni zbritjen.</p>
                <form asp-action="BulkDiscount" method="post" id="bulkDiscountForm">
                    @Html.AntiForgeryToken()
                    <div id="selectedProductInputs"></div>
                    <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap">
                        <input type="number" name="discountPercent" min="1" max="90" value="10"
                               placeholder="%" class="form-input" style="width:100px" />
                        <span style="color:var(--admin-muted)">% zbritje</span>
                        <button type="button" onclick="submitBulkDiscount()"
                                class="promo-btn promo-btn-orange">
                            ⚡ Apliko Zbritjen
                        </button>
                    </div>
                </form>
            </div>

            <!-- Clear All -->
            <div class="promo-action-card">
                <h4>🗑️ Pastro Të Gjitha Zbritjet</h4>
                <p>Heq çmimin e zbritur nga të gjitha produktet aktive.</p>
                <form asp-action="ClearAllSalePrices" method="post"
                      onsubmit="return confirm('A jeni i sigurt? Kjo do të heqë TË GJITHA zbritjet.')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="promo-btn promo-btn-red">🗑️ Pastro Zbritjet</button>
                </form>
            </div>

            <!-- Newsletter Blast -->
            <div class="promo-action-card" style="grid-column:1/-1">
                <h4>📧 Dërgoni Buletin tek Abonentët (@subscriberCount)</h4>
                @if (!emailConfigured)
                {
                    <div class="promo-warning">
                        ⚠️ <strong>Email nuk është konfiguruar.</strong>
                        Vendosni EMAIL_SMTP_HOST, EMAIL_SMTP_USER dhe EMAIL_SMTP_PASS në variablat e mjedisit.
                    </div>
                }
                <form asp-action="SendNewsletter" method="post" id="newsletterForm">
                    @Html.AntiForgeryToken()
                    <div class="form-group" style="margin-bottom:12px">
                        <input type="text" name="subject" class="form-input"
                               placeholder="Subjekti i emailit..." required style="width:100%" />
                    </div>
                    <div class="form-group" style="margin-bottom:12px">
                        <textarea name="htmlBody" class="form-textarea" rows="4"
                                  placeholder="Permbajtja HTML e buletinit..." required
                                  style="width:100%;font-size:0.9rem"></textarea>
                    </div>
                    <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap">
                        <button type="submit" class="promo-btn promo-btn-purple"
                                @(subscriberCount == 0 ? "disabled" : "")
                                onclick="return confirm('A jeni i sigurt? Do t\\'i dërgoni email @subscriberCount abonentëve.')">
                            📧 Dërgo Buletinin
                        </button>
                        @if (subscriberCount == 0)
                        {
                            <span style="color:var(--admin-muted);font-size:0.85rem">Nuk ka abonentë aktivë.</span>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Product Filters -->
    <div class="promo-panel">
        <div class="promo-panel-header">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
            </svg>
            <h3>Menaxhimi i Produkteve (@products.Count produkte)</h3>
        </div>

        <div style="margin-bottom:1rem">
            <form method="get" style="display:flex;gap:12px;flex-wrap:wrap">
                <input name="q" class="form-input" placeholder="Kërko..." value="@ViewBag.Query" style="max-width:250px" />
                <select name="catId" class="sort-select">
                    <option value="">Të gjitha kategoritë</option>
                    @foreach (var c in categories)
                    {
                        <option value="@c.Id" selected="@(ViewBag.SelectedCat?.ToString() == c.Id.ToString())">@c.Name</option>
                    }
                </select>
                <button type="submit" class="promo-btn" style="background:var(--admin-primary)">Kërko</button>
            </form>
        </div>

        <div class="promo-legend">
            <span>💡 Tip: Klikoni <b>⭐ Featured</b> ose <b>🔥 Bestseller</b> për të ndryshuar statusin. Klikoni <b>📉 Çmimi</b> për të vendosur zbritje direkt.</span>
        </div>

        <div class="promo-table-wrap">
            <table class="admin-table promo-table" id="promoTable">
                <thead>
                    <tr>
                        <th><input type="checkbox" id="selectAll" onchange="toggleSelectAll(this)" title="Zgjidh të gjitha"></th>
                        <th>Produkti</th>
                        <th>Çmimi</th>
                        <th style="text-align:center">Zbritja</th>
                        <th style="text-align:center">⭐ Featured</th>
                        <th style="text-align:center">🔥 Bestseller</th>
                        <th>Kategoria</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in products)
                    {
                        <tr id="row-@p.Id" class="@(p.IsOnSale ? "row-on-sale" : "")">
                            <td>
                                <input type="checkbox" class="product-checkbox" value="@p.Id" />
                            </td>
                            <td>
                                <div style="display:flex;align-items:center;gap:10px">
                                    <img src="@(p.ImageUrl ?? "/img/placeholder.png")"
                                         style="width:36px;height:36px;object-fit:cover;border-radius:6px" alt="" />
                                    <div>
                                        <strong style="font-size:0.9rem">@p.Name</strong>
                                        @if (!string.IsNullOrEmpty(p.Brand))
                                        {
                                            <small style="color:var(--admin-muted);display:block">@p.Brand</small>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div>
                                    <span style="font-weight:700">@p.Price.ToString("F2") €</span>
                                    @if (p.IsOnSale)
                                    {
                                        <br/>
                                        <span class="sale-tag" id="saletag-@p.Id">
                                            📉 @p.DisplayPrice.ToString("F2") € (-@p.DiscountPercent%)
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="sale-tag" id="saletag-@p.Id" style="display:none"></span>
                                    }
                                </div>
                            </td>
                            <td style="text-align:center">
                                <div class="sale-price-control">
                                    <input type="number" step="0.01" min="0" max="@(p.Price - 0.01m)"
                                           class="form-input sale-input"
                                           id="sale-input-@p.Id"
                                           value="@(p.SalePrice.HasValue ? p.SalePrice.Value.ToString("F2") : "")"
                                           placeholder="0.00" style="width:80px;font-size:0.85rem" />
                                    <button onclick="setSalePrice(@p.Id)" class="promo-btn-mini promo-btn-orange"
                                            title="Apliko çmimin e zbritur">✓</button>
                                    <button onclick="clearSalePrice(@p.Id)" class="promo-btn-mini promo-btn-red"
                                            title="Hiq zbritjen">✕</button>
                                </div>
                            </td>
                            <td style="text-align:center">
                                <button onclick="toggleFeatured(@p.Id, this)"
                                        class="toggle-btn @(p.IsFeatured ? "toggle-on" : "toggle-off")"
                                        id="feat-@p.Id"
                                        title="@(p.IsFeatured ? "Largo nga Featured" : "Shto te Featured")">
                                    @(p.IsFeatured ? "⭐ Po" : "☆ Jo")
                                </button>
                            </td>
                            <td style="text-align:center">
                                <button onclick="toggleMostSold(@p.Id, this)"
                                        class="toggle-btn @(p.IsMostSold ? "toggle-on toggle-fire" : "toggle-off")"
                                        id="sold-@p.Id"
                                        title="@(p.IsMostSold ? "Largo nga Bestseller" : "Shto te Bestseller")">
                                    @(p.IsMostSold ? "🔥 Po" : "○ Jo")
                                </button>
                            </td>
                            <td style="color:var(--admin-muted);font-size:0.85rem">
                                @(p.CategoryName ?? "—")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .promo-stats-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1rem;
        margin-bottom: 2rem;
    }
    .promo-stat {
        background: var(--admin-surface);
        border: 1px solid var(--admin-border);
        border-radius: 14px;
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    .promo-stat-icon { font-size: 2rem; }
    .promo-stat strong {
        display: block;
        font-size: 1.8rem;
        font-weight: 800;
        color: #fff;
        line-height: 1.1;
    }
    .promo-stat span {
        font-size: 0.8rem;
        color: var(--admin-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .promo-panel {
        background: var(--admin-surface);
        border: 1px solid var(--admin-border);
        border-radius: 16px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
    }
    .promo-panel-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 1.25rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--admin-border);
    }
    .promo-panel-header h3 {
        margin: 0;
        font-size: 1.1rem;
        color: #fff;
    }

    .promo-actions-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }
    @@media (max-width: 768px) {
        .promo-actions-grid { grid-template-columns: 1fr; }
    }

    .promo-action-card {
        background: rgba(0,0,0,0.2);
        border: 1px solid var(--admin-border);
        border-radius: 12px;
        padding: 1.25rem;
    }
    .promo-action-card h4 {
        color: #fff;
        font-size: 0.95rem;
        margin-bottom: 0.5rem;
    }
    .promo-action-card p {
        color: var(--admin-muted);
        font-size: 0.85rem;
        margin-bottom: 1rem;
    }

    .promo-btn {
        padding: 0.6rem 1.2rem;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.875rem;
        cursor: pointer;
        transition: all 0.2s;
        color: white;
        background: var(--admin-primary);
    }
    .promo-btn:hover { opacity: 0.85; transform: translateY(-1px); }
    .promo-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }
    .promo-btn-orange { background: #f97316; }
    .promo-btn-red { background: #ef4444; }
    .promo-btn-purple { background: #8b5cf6; }

    .promo-warning {
        background: rgba(245, 158, 11, 0.1);
        border: 1px solid rgba(245, 158, 11, 0.3);
        border-radius: 8px;
        padding: 0.75rem 1rem;
        color: #f59e0b;
        font-size: 0.875rem;
        margin-bottom: 1rem;
    }

    .promo-legend {
        background: rgba(99, 102, 241, 0.1);
        border: 1px solid rgba(99, 102, 241, 0.2);
        border-radius: 8px;
        padding: 0.75rem 1rem;
        color: var(--admin-muted);
        font-size: 0.85rem;
        margin-bottom: 1rem;
    }

    .promo-table-wrap {
        overflow-x: auto;
    }

    .promo-table { min-width: 700px; }

    .row-on-sale { background: rgba(16, 185, 129, 0.05) !important; }

    .sale-tag {
        font-size: 0.78rem;
        color: #10b981;
        font-weight: 600;
        background: rgba(16, 185, 129, 0.1);
        padding: 2px 6px;
        border-radius: 4px;
    }

    .sale-price-control {
        display: flex;
        gap: 4px;
        align-items: center;
        justify-content: center;
    }
    .promo-btn-mini {
        width: 28px;
        height: 28px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        font-size: 0.8rem;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        font-weight: 700;
        padding: 0;
    }
    .promo-btn-mini:hover { opacity: 0.8; transform: scale(1.1); }

    .toggle-btn {
        padding: 0.35rem 0.85rem;
        border: 1px solid var(--admin-border);
        border-radius: 20px;
        cursor: pointer;
        font-size: 0.8rem;
        font-weight: 600;
        transition: all 0.25s;
        background: transparent;
        white-space: nowrap;
    }
    .toggle-off { color: var(--admin-muted); }
    .toggle-off:hover { border-color: #6366f1; color: #6366f1; }
    .toggle-on { color: #f59e0b; border-color: #f59e0b; background: rgba(245,158,11,0.1); }
    .toggle-fire { color: #f97316; border-color: #f97316; background: rgba(249,115,22,0.1); }
</style>

@section Scripts {
<script>
    // -- Select all checkboxes
    function toggleSelectAll(master) {
        document.querySelectorAll('.product-checkbox').forEach(cb => cb.checked = master.checked);
    }

    // -- Submit bulk discount with selected product IDs
    function submitBulkDiscount() {
        const selected = [...document.querySelectorAll('.product-checkbox:checked')].map(c => c.value);
        if (selected.length === 0) { alert('Zgjidh të paktën një produkt.'); return; }
        const container = document.getElementById('selectedProductInputs');
        container.innerHTML = '';
        selected.forEach(id => {
            const inp = document.createElement('input');
            inp.type = 'hidden';
            inp.name = 'productIds';
            inp.value = id;
            container.appendChild(inp);
        });
        if (confirm(`Apliko zbritjen tek ${selected.length} produkte?`)) {
            document.getElementById('bulkDiscountForm').submit();
        }
    }

    // -- Toggle Featured via AJAX
    function toggleFeatured(id, btn) {
        fetch(`/Admin/ToggleFeatured?id=${id}`, { method: 'POST', headers: { 'RequestVerificationToken': getToken() } })
            .then(r => r.json())
            .then(d => {
                if (d.success) {
                    btn.textContent = d.isFeatured ? '⭐ Po' : '☆ Jo';
                    btn.className = 'toggle-btn ' + (d.isFeatured ? 'toggle-on' : 'toggle-off');
                }
            });
    }

    // -- Toggle MostSold via AJAX
    function toggleMostSold(id, btn) {
        fetch(`/Admin/ToggleMostSold?id=${id}`, { method: 'POST', headers: { 'RequestVerificationToken': getToken() } })
            .then(r => r.json())
            .then(d => {
                if (d.success) {
                    btn.textContent = d.isMostSold ? '🔥 Po' : '○ Jo';
                    btn.className = 'toggle-btn ' + (d.isMostSold ? 'toggle-on toggle-fire' : 'toggle-off');
                }
            });
    }

    // -- Set sale price via AJAX
    function setSalePrice(id) {
        const val = parseFloat(document.getElementById(`sale-input-${id}`).value);
        if (isNaN(val) || val <= 0) { alert('Vendos çmim të vlefshëm.'); return; }
        fetch(`/Admin/SetSalePrice`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': getToken() },
            body: `id=${id}&salePrice=${val}`
        }).then(r => r.json()).then(d => {
            if (d.success) {
                const tag = document.getElementById(`saletag-${id}`);
                tag.textContent = `📉 ${d.salePrice.toFixed(2)} € (-${d.discountPercent}%)`;
                tag.style.display = '';
                document.getElementById(`row-${id}`).classList.add('row-on-sale');
            } else { alert(d.error || 'Gabim.'); }
        });
    }

    // -- Clear sale price via AJAX
    function clearSalePrice(id) {
        document.getElementById(`sale-input-${id}`).value = '';
        fetch(`/Admin/SetSalePrice`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': getToken() },
            body: `id=${id}&salePrice=0`
        }).then(r => r.json()).then(d => {
            if (d.success) {
                const tag = document.getElementById(`saletag-${id}`);
                tag.textContent = '';
                tag.style.display = 'none';
                document.getElementById(`row-${id}`).classList.remove('row-on-sale');
            }
        });
    }

    function getToken() {
        const el = document.querySelector('input[name="__RequestVerificationToken"]');
        return el ? el.value : '';
    }
</script>
}
