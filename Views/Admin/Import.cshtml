@{
    ViewData["Title"] = "Import CSV — Admin";
}

<div class="admin-page">
    <div class="admin-header">
        <h1>?? Import Produktet nga CSV</h1>
        <div class="admin-nav">
            <a asp-action="Products" class="admin-nav-link">? Kthehu</a>
        </div>
    </div>

    @if (TempData["Success"] != null) { <div class="alert-success">? @TempData["Success"]</div> }
    @if (TempData["Error"]   != null) { <div class="alert-error">? @TempData["Error"]</div> }

    <div class="admin-form-wrap">
        <div class="info-box">
            <h3>?? Formati i skedarit CSV</h3>
            <p>Skedari duhet të ketë kolonat në këtë rend:</p>
            <code>Barkodi, Emri, Çmimi, Kategoria, Marka, Njësia, Stoku</code>
            <br/><br/>
            <p>Shembull:</p>
            <pre>1234567890,Laptop Lenovo,649.00,Elektronikë,Lenovo,Copë,10
9876543210,Kafë Lavazza 1kg,12.50,Ushqim & Pije,Lavazza,KG,50</pre>
        </div>

        <form asp-action="Import" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label>Zgjidh skedarin CSV</label>
                <input type="file" name="csvFile" accept=".csv" class="form-input" />
            </div>
            <button type="submit" class="btn-primary">?? Import</button>
        </form>
    </div>
</div>
