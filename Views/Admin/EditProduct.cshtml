@model ProjectTemplate.Models.Ecommerce.Product
@{
    ViewData["Title"] = (Model.Id == 0 ? "Produkt i Ri" : "Edito Produktin") + " — Admin";
    var categories = ViewBag.Categories as List<ProjectTemplate.Models.Ecommerce.ProductCategory> ?? new();
}

<div class="admin-page">
    <div class="admin-header">
        <h1>@(Model.Id == 0 ? "➕ Produkt i Ri" : "✏️ Edito Produktin")</h1>
        <div class="admin-nav">
            <a asp-action="Products" class="admin-nav-link">← Kthehu</a>
        </div>
    </div>

    <div class="admin-form-wrap">
        <form asp-action="EditProduct" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Name">Emri i Produktit *</label>
                    <input asp-for="Name" class="form-input" />
                    <span asp-validation-for="Name" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Brand">Marka</label>
                    <input asp-for="Brand" class="form-input" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Price">Çmimi (€) *</label>
                    <input asp-for="Price" type="number" step="0.01" class="form-input" />
                    <span asp-validation-for="Price" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="SalePrice">Çmimi i Zbritur (€)</label>
                    <input asp-for="SalePrice" type="number" step="0.01" class="form-input" placeholder="Lë bosh nëse nuk ka zbritje" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="CategoryId">Kategoria</label>
                    <select asp-for="CategoryId" class="sort-select form-input">
                        <option value="">-- Zgjidh kategorinë --</option>
                        @foreach (var c in categories)
                        {
                            <option value="@c.Id" selected="@(Model.CategoryId == c.Id)">@c.Name</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label asp-for="Unit">Njësia</label>
                    <input asp-for="Unit" class="form-input" placeholder="Copë, KG, Palë..." />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="StockQuantity">Sasia në Stok</label>
                    <input asp-for="StockQuantity" type="number" step="0.01" class="form-input" />
                </div>
                <div class="form-group">
                    <label asp-for="Barcode">Barkodi</label>
                    <input asp-for="Barcode" class="form-input" />
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Description">Përshkrimi</label>
                <textarea asp-for="Description" class="form-textarea" rows="4"></textarea>
            </div>

            <div class="form-group">
                <label asp-for="ImageUrl">URL e Imazhit</label>
                <input asp-for="ImageUrl" class="form-input" placeholder="https://..." />
            </div>

            <div class="form-row">
                <div class="form-group" style="flex-direction:row;align-items:center;gap:12px">
                    <input type="checkbox" asp-for="IsActive" id="isActive" />
                    <label for="isActive">Produkt Aktiv</label>
                </div>
                <div class="form-group" style="flex-direction:row;align-items:center;gap:12px">
                    <input type="checkbox" asp-for="IsFeatured" id="isFeatured" />
                    <label for="isFeatured">I Rekomanduar (Featured)</label>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary">💾 Ruaj</button>
                <a asp-action="Products" class="btn-ghost">Anulo</a>
            </div>
        </form>
    </div>
</div>
