<!DOCTYPE html>
<html lang="sq">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — Enisi Center" : "Enisi Center | Dyqani Juaj Online")</title>
    <meta name="description" content="@(ViewData["Description"] ?? "Enisi Center – dyqani juaj online me produktet më cilësore. Blini me besim, me çmime konkurruese dhe dorëzim të shpejtë.")" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Outfit:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" type="image/png" href="~/logo.png" />
</head>
<body>
    <!-- -- Top Bar --------------------------------------------------------- -->
    <div class="top-bar">
        <span>🚚 Dorëzim falas për porosi mbi 50€</span>
        <span class="top-bar-hide-sm">📞 +383 45 594 549</span>
        <span class="top-bar-hide-sm">📍 Podujevë, Kosovë</span>
    </div>

    <!-- -- Navigation ------------------------------------------------------ -->
    <header class="site-header" id="siteHeader">
        <div class="header-inner">
            <a class="site-logo" asp-controller="Home" asp-action="Index" aria-label="Enisi Center - Ballina">
                <img src="~/logo.png" alt="Enisi Center Logo" class="site-logo-img" />
            </a>

            <!-- Search bar -->
            <div class="header-search">
                <form asp-controller="Shop" asp-action="Index" method="get" class="search-form" role="search">
                    <input type="text" name="q" id="searchInput" class="search-input"
                           placeholder="Kërko produkte..." value="@ViewData["SearchQuery"]"
                           autocomplete="off" aria-label="Kërko produkte" />
                    <button type="submit" class="search-btn" aria-label="Kërko">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        </svg>
                    </button>
                </form>
                <div id="searchSuggestions" class="search-suggestions" role="listbox" aria-live="polite"></div>
            </div>

            <!-- Actions -->
            <div class="header-actions">
                <a asp-controller="Shop" asp-action="Index" class="header-action" title="Dyqani" aria-label="Dyqani">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
                        <line x1="3" y1="6" x2="21" y2="6"/>
                        <path d="M16 10a4 4 0 01-8 0"/>
                    </svg>
                    <span class="action-label">Dyqani</span>
                </a>
                <a asp-controller="Cart" asp-action="Index" class="header-action cart-action" title="Shporta" aria-label="Shporta">
                    <span class="cart-badge" id="cartBadge" aria-label="Artikuj në shportë">@(ViewData["CartCount"] ?? 0)</span>
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                        <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 001.96-1.61L23 6H6"/>
                    </svg>
                    <span class="action-label">Shporta</span>
                </a>
                <button class="hamburger-btn" id="mobileMenuBtn" aria-label="Hap menynë" aria-expanded="false" aria-controls="catNav">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <line x1="3" y1="6" x2="21" y2="6"/>
                        <line x1="3" y1="12" x2="21" y2="12"/>
                        <line x1="3" y1="18" x2="21" y2="18"/>
                    </svg>
                </button>
            </div>
        </div>

        <!-- -- Category Navigation ---------------------------------------- -->
        <nav class="cat-nav" id="catNav" aria-label="Kategorite kryesore">
            <div class="cat-nav-inner">
                <a asp-controller="Home" asp-action="Index" class="cat-nav-item">Ballina</a>
                <a asp-controller="Shop" asp-action="Index" class="cat-nav-item">Të gjitha</a>
                <a asp-controller="Shop" asp-action="Index" asp-route-q="Elektroshtepiake" class="cat-nav-item">Elektroshtepiake</a>
                <a asp-controller="Shop" asp-action="Index" asp-route-q="Elektronikë" class="cat-nav-item">Elektronikë</a>
                <a asp-controller="Shop" asp-action="Index" asp-route-q="Ushqim" class="cat-nav-item">Ushqim &amp; Pije</a>
                <a asp-controller="Shop" asp-action="Index" asp-route-q="Veshmbathje" class="cat-nav-item">Veshmbathje</a>
                <a asp-controller="Shop" asp-action="Index" asp-route-q="Kozmetikë" class="cat-nav-item">Kozmetikë</a>
                <a asp-controller="Shop" asp-action="Index" asp-route-q="Shtëpi" class="cat-nav-item">Shtëpi &amp; Kuzhinë</a>
                <a asp-controller="Home" asp-action="About" class="cat-nav-item">Rreth Nesh</a>
                <a asp-controller="Home" asp-action="Contact" class="cat-nav-item">Kontakt</a>
            </div>
        </nav>
    </header>

    <main class="site-main" id="mainContent">
        @if (TempData["SubscribeSuccess"] != null)
        {
            <div class="subscribe-toast subscribe-toast-success" role="alert">
                ✅ @TempData["SubscribeSuccess"]
            </div>
        }
        @if (TempData["SubscribeError"] != null)
        {
            <div class="subscribe-toast subscribe-toast-error" role="alert">
                ❌ @TempData["SubscribeError"]
            </div>
        }
        @RenderBody()
    </main>

    <!-- -- Footer ---------------------------------------------------------- -->
    <footer class="site-footer" aria-label="Footer">
        <!-- Newsletter subscription row -->
        <div class="footer-newsletter">
            <div class="footer-newsletter-inner">
                <div class="footer-newsletter-text">
                    <h3>📧 Abonohu në Newsletter</h3>
                    <p>Merr oferta ekskluzive dhe lajme nga Enisi Center direkt në email.</p>
                </div>
                <form asp-controller="Home" asp-action="Subscribe" method="post" class="footer-newsletter-form" novalidate>
                    @Html.AntiForgeryToken()
                    <input type="email" name="email" placeholder="emaili@yt.com" required
                           aria-label="Emaili juaj" class="newsletter-input" />
                    <button type="submit" class="newsletter-btn" aria-label="Abonohu">
                        Abonohu →
                    </button>
                </form>
            </div>
        </div>

        <div class="footer-inner">
            <div class="footer-brand-col">
                <a class="site-logo-footer" asp-controller="Home" asp-action="Index" aria-label="Enisi Center - Ballina">
                    <img src="~/logo.png" alt="Enisi Center Logo" class="footer-logo-img" />
                </a>
                <p class="footer-desc">Dyqani juaj i besueshëm online.<br>Produkte cilësore, çmime konkurruese dhe shërbim i shkëlqyer për çdo klient.</p>
                <div class="footer-social" aria-label="Rrjete sociale">
                    <a href="https://facebook.com" aria-label="Facebook" class="social-link" target="_blank" rel="noopener">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"></path></svg>
                    </a>
                    <a href="https://instagram.com" aria-label="Instagram" class="social-link" target="_blank" rel="noopener">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                    </a>
                    <a href="https://wa.me/38345594549" aria-label="WhatsApp" class="social-link" target="_blank" rel="noopener">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"></path></svg>
                    </a>
                </div>
            </div>

            <div class="footer-links-grid">
                <div class="footer-col">
                    <h4>Dyqani</h4>
                    <a asp-controller="Shop" asp-action="Index">Të gjitha produktet</a>
                    <a asp-controller="Shop" asp-action="Index" asp-route-sort="newest">Të rejat</a>
                    <a asp-controller="Shop" asp-action="Index" asp-route-sort="price_asc">Çmimi më i ulët</a>
                    <a asp-controller="Cart" asp-action="Index">Shporta ime</a>
                </div>
                <div class="footer-col">
                    <h4>Informacione</h4>
                    <a asp-controller="Home" asp-action="About">Rreth Nesh</a>
                    <a asp-controller="Home" asp-action="Contact">Kontakto</a>
                    <a asp-controller="Home" asp-action="Faq">Pyetjet (FAQ)</a>
                </div>
                <div class="footer-col">
                    <h4>Kontakt</h4>
                    <ul class="footer-contact-info">
                        <li><span aria-hidden="true">📍</span> Podujevë, Kosovë</li>
                        <li><span aria-hidden="true">📞</span> <a href="tel:+38345594549" style="color:inherit">+383 45 594 549</a></li>
                        <li><span aria-hidden="true">📧</span> <a href="mailto:info@enisicenter.tech" style="color:inherit">info@enisicenter.tech</a></li>
                        <li><span aria-hidden="true">🕒</span> E Hënë–E Shtunë: 08:00–20:00</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="footer-bottom">
            <p>© @DateTime.Now.Year Enisi Center. Të gjitha të drejtat e rezervuara.</p>
            <div class="payment-badges">
                <span class="payment-badge">💳 Kartë</span>
                <span class="payment-badge">💵 Cash</span>
                <span class="payment-badge">🏦 Transfer</span>
            </div>
        </div>
    </footer>

    <!-- Floating WhatsApp Button -->
    <a href="https://wa.me/38345594549" target="_blank" rel="noopener" class="floating-wa" aria-label="Na kontaktoni në WhatsApp">
        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"></path>
        </svg>
    </a>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
