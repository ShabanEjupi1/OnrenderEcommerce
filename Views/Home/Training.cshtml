@model List<LeaderboardEntry>
@{
    var isSq = System.Threading.Thread.CurrentThread.CurrentUICulture.Name == "sq";
    ViewData["Title"] = isSq ? "Trajnim & Demo" : "Training & Demo";
}

<div class="hero">
    <div class="hero-inner">
        <div class="hero-eyebrow">@(isSq ? "Qendra e Mësimit dhe Trajnimit" : "Learning and Training Center")</div>
        <h1 class="hero-title">@(isSq ? "Qendra e Trajnimit" : "Training Hub")</h1>
        <p class="hero-sub">@(isSq ? "Përdoreni këtë faqe për mësim, onboardim ose vlerësime" : "Use this page for lessons, onboarding, or assessments")</p>
        <p class="hero-desc">
            @(isSq 
                ? Html.Raw("Përdorni këtë seksion si pikënisje për <strong>module trajnimi, kuize ose simulime</strong>. Të dyja rrjedhat ekzistuese mund t'i zëvendësoni me përmbajtjen e projektit tuaj.")
                : Html.Raw("Use this section as a starting point for <strong>training modules, quizzes, or simulations</strong>. Both existing paths can be replaced with your own project content."))
        </p>

        <div class="concept-chips">
            <span class="chip">@(isSq ? "Variablat" : "Variables")</span>
            <span class="chip">@(isSq ? "Llojet e të Dhënave" : "Data Types")</span>
            <span class="chip">@(isSq ? "Kushtet" : "Conditionals")</span>
            <span class="chip">@(isSq ? "Unazat" : "Loops")</span>
            <span class="chip">@(isSq ? "Funksionet" : "Functions")</span>
            <span class="chip">@(isSq ? "Listat" : "Lists")</span>
            <span class="chip">@(isSq ? "Fjalorët" : "Dictionaries")</span>
            <span class="chip">@(isSq ? "Klasat" : "Classes")</span>
            <span class="chip">@(isSq ? "Gabimet" : "Exceptions")</span>
            <span class="chip">@(isSq ? "Asinkron/Prit" : "Async/Await")</span>
            <span class="chip">@(isSq ? "API-të" : "APIs")</span>
            <span class="chip">@(isSq ? "Bazat e të Dhënave" : "Databases")</span>
            <span class="chip">@(isSq ? "Kontrolli i Versioneve" : "Version Control")</span>
            <span class="chip">@(isSq ? "Trashëgimia" : "Inheritance")</span>
            <span class="chip">@(isSq ? "Testimi i Njësive" : "Unit Testing")</span>
        </div>

        <form method="post" asp-controller="Home" asp-action="Start" class="start-form">
            <input type="text"
                   name="PlayerName"
                   class="name-input"
                   placeholder="@(isSq ? "Shënoni emrin tuaj, Menaxher i Sistemit…" : "Enter your name, System Manager…")"
                   maxlength="40"
                   autocomplete="off"
                   required />
            <select name="Language" class="name-input" style="width: auto;">
                <option value="en">English</option>
                <option value="sq">Shqip</option>
            </select>
            <select name="GameType" class="name-input" style="width: auto;">
                <option value="Coding">@(isSq ? "Mëso Programim" : "Learn Coding")</option>
                <option value="POS">@(isSq ? "Trajnim Operacional" : "Operational Training")</option>
            </select>
            <button type="submit" class="btn-primary">@(isSq ? "Nis Trajnimin →" : "Start Training →")</button>
        </form>
    </div>

    <div class="hero-deco" aria-hidden="true">
        <div class="deco-ring r1"></div>
        <div class="deco-ring r2"></div>
        <div class="deco-ring r3"></div>
        <span class="deco-glyph">◆</span>
    </div>
</div>

@if (Model.Any())
{
    <section class="home-leaderboard">
        <h2 class="section-title">@(isSq ? "Pjesëmarrësit më të mirë" : "Top Participants")</h2>
        <table class="lb-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>@(isSq ? "Emri" : "Name")</th>
                    <th>@(isSq ? "Pikët" : "Score")</th>
                    <th>@(isSq ? "Të Sakta" : "Correct")</th>
                    <th>@(isSq ? "Rangu" : "Rank")</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Count; i++)
                {
                    var e = Model[i];
                    <tr class="@(i == 0 ? "top-row" : "")">
                        <td class="rank-num">@(i + 1)</td>
                        <td>@e.PlayerName</td>
                        <td class="score-cell">@e.Score</td>
                        <td>@e.CorrectAnswers</td>
                        <td><span class="rank-badge">@e.Rank</span></td>
                    </tr>
                }
            </tbody>
        </table>
        <a asp-controller="Game" asp-action="Leaderboard" class="lb-link">@(isSq ? "Shiko të gjithë liderët →" : "View full leaderboard →")</a>
    </section>
}


