@{
    var isSq = System.Threading.Thread.CurrentThread.CurrentUICulture.Name == "sq";
    ViewData["Title"] = isSq ? "Pyetjet" : "FAQ";
}

<div class="hero">
    <h1 class="hero-title">@(isSq ? "Pyetjet e Bëra Më Shpesh" : "Frequently Asked Questions")</h1>
    <p class="hero-desc">@(isSq ? "Keni pyetje për Enisi Center? Ne kemi përgjigjet që po i kërkoni." : "Got questions about Enisi Center? We have the answers you're looking for.")</p>
</div>

<div class="faq-section">
    <div class="faq-item">
        <h3>@(isSq ? "Çfarë është Enisi Center?" : "What is Enisi Center?")</h3>
        <p>@(isSq ? "Enisi Center është dyqani juaj i besuar online që ofron një gamë të gjerë produktesh duke përfshirë elektronikë, pajisje shtëpiake, ushqim dhe shumë më tepër, me çmime konkurruese." : "Enisi Center is your trusted online store offering a wide range of products including electronics, home appliances, food, and much more at competitive prices.")</p>
    </div>

    <div class="faq-item">
        <h3>@(isSq ? "Si mund të bëj një porosi?" : "How can I place an order?")</h3>
        <p>@(isSq ? "Ju mund të porosisni shumë lehtë duke i shtuar produktet në shportë dhe duke vazhduar në arkë për të plotësuar të dhënat e dërgesës." : "You can easily order by adding products to your cart and proceeding to checkout to fill in your delivery details.")</p>
    </div>

    <div class="faq-item">
        <h3>@(isSq ? "Cilat janë metodat e pagesës?" : "What are the payment methods?")</h3>
        <p>@(isSq ? "Ne ofrojmë pagesë me para në dorëzim (Cash) dhe pagesa përmes kartës suaj bankare." : "We offer cash on delivery and payments via your bank card.")</p>
    </div>

    <div class="faq-item">
        <h3>@(isSq ? "Sa kohë zgjat dërgesa?" : "How long does shipping take?")</h3>
        <p>@(isSq ? "Dërgesat realizohen në mënyrë të shpejtë brenda 24 deri në 48 orë në të gjithë territorin e Kosovës." : "Deliveries are made quickly within 24 to 48 hours throughout the territory of Kosova.")</p>
    </div>

    <div class="faq-item">
        <h3>@(isSq ? "A mund t'i kthej produktet e blera?" : "Can I return purchased products?")</h3>
        <p>@(isSq ? "Po, nëse produkti nuk i përmbush pritshmëritë tuaja ose është i dëmtuar, mund të inicionin kthimin bazuar në rregullat tona të kthimit." : "Yes, if the product does not meet your expectations or is damaged, you can initiate a return based on our return policy.")</p>
    </div>
</div>

