@{
    var isSq = System.Threading.Thread.CurrentThread.CurrentUICulture.Name == "sq";
    ViewData["Title"] = isSq ? "Rreth Nesh" : "About Us";
}

<div class="hero">
    <div class="hero-inner" style="max-width: 1200px; margin: auto;">
        <h1 class="hero-title">@(isSq ? "Rreth Nesh" : "About Us")</h1>
        <p class="hero-sub">@(isSq ? "Historia e Enisi Center" : "The story of Enisi Center")</p>
        <p class="hero-desc" style="font-size: 1.25em; line-height: 1.6; max-width: 800px; margin: 0 auto 40px auto; text-align: left;">
            @(isSq ? "Enisi Center nisi si një nismë për të sjellë produktet e nevojshme më pranë qytetarëve me një shërbim cilësor. Sot jemi rritur dhe e kemi transformuar përvojën tonë në një dyqan modern online, të gatshëm për të plotësuar çdo kërkesë tuajën." : "Enisi Center started as an initiative to bring necessary products closer to citizens with quality service. Today we have grown and transformed our experience into a modern online store, ready to fulfill all your needs.")
        </p>

        <div style="text-align: left; max-width: 800px; margin: 0 auto 40px auto; background: rgba(0,0,0,0.3); padding: 30px; border-radius: 8px;">
            <h3>@(isSq ? "Si filloi gjithçka" : "How It All Started")</h3>
            <p>
                @(isSq ? "Filluam me një dyqan të thjeshtë lokal me qëllimin e vetëm për të ofruar produkte të besueshme për klientët tanë. Përkushtimi ynë ndaj cilësisë dhe çmimeve të drejta na bëri të fitojmë shpejt besimin e komunitetit." : "We started with a simple local store with the sole purpose of offering reliable products to our customers. Our dedication to quality and fair prices made us quickly earn the trust of the community.")
            </p>
            <p>
                @(isSq ? "Me zhvillimin e teknologjisë, pamë nevojën për t'u digjitalizuar. Kështu krijuam këtë platformë e cila na mundëson t'i shërbejmë klientëve kudo në Kosovë me të njëjtin standard të lartë." : "With the development of technology, we saw the need to digitize. Thus we created this platform which enables us to serve customers anywhere in Kosova with the same high standard.")
            </p>
            <p>
                @(isSq ? "Cilësia, shpejtësia dhe besueshmëria mbeten shtyllat kryesore të operimit tonë të përditshëm." : "Quality, speed, and reliability remain the main pillars of our daily operations.")
            </p>
        </div>

        <div style="display: flex; gap: 30px; margin-top: 50px; flex-wrap: wrap;">
            <div style="flex: 1; min-width: 300px; background: rgba(0,0,0,0.5); padding: 30px; border-radius: 8px;">
                <h3 style="color: #4caf50;">@(isSq ? "Vizioni Ynë" : "Our Vision")</h3>
                <p>@(isSq ? "Të jemi destinacioni kryesor i blerjeve online, duke u ofruar klientëve lehtësi, shumëllojshmëri artikujsh dhe siguri maksimale në çdo porosi." : "To be the premier destination for online shopping, offering customers convenience, variety of items, and maximum security in every order.")</p>
            </div>
            <div style="flex: 1; min-width: 300px; background: rgba(0,0,0,0.5); padding: 30px; border-radius: 8px;">
                <h3 style="color: #2196f3;">@(isSq ? "Përkushtimi Ndaj Klientit" : "Commitment to the Customer")</h3>
                <p>@(isSq ? "Klienti është në qendër të çdo gjëje që bëjmë. Kujdesi ndaj tyre na motivon të përmirësohemi pa rreshtur çdo ditë e më shumë." : "The customer is at the center of everything we do. Caring for them motivates us to continuously improve every single day.")</p>
            </div>
        </div>
    </div>
</div>

