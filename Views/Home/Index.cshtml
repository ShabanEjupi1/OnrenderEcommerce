@{
    ViewData["Title"] = "Ballina";
    ViewData["Description"] = "Enisi Center – dyqani juaj online me oferta të parezistueshme. Blini elektronikë, veshmbathje, ushqim dhe shumë më tepër.";
}

<!-- -- Hero Section ------------------------------------------------------ -->
<section class="ec-hero">
    <div class="ec-hero-content">
        <div class="hero-badge">✨ Oferta Speciale Pranverë 2025</div>
        <h1 class="ec-hero-title">
            Blini me <em>stil</em>,<br/>kurseni me <em>kuptim</em>
        </h1>
        <p class="ec-hero-subtitle">
            Mijëra produkte me çmime konkurruese, dorëzim i shpejtë dhe shërbim i pakrahasueshëm.
        </p>
        <div class="hero-actions">
            <a asp-controller="Shop" asp-action="Index" class="btn-primary-lg">
                Shfleto Produktet &rarr;
            </a>
            <a asp-controller="Home" asp-action="About" class="btn-ghost-lg">
                Mëso Më Shumë
            </a>
        </div>
        <div class="hero-stats">
            <div class="stat"><strong>500+</strong><span>Produkte</span></div>
            <div class="stat"><strong>24h</strong><span>Dorëzim</span></div>
            <div class="stat"><strong>100%</strong><span>Garanci</span></div>
        </div>
    </div>
    <div class="ec-hero-visual">
        <div class="hero-card-stack">
            <div class="hero-card hero-card-1">
                <div class="card-emoji">✨</div>
                <div>Elektronikë</div>
                <strong>Nga 49€</strong>
            </div>
            <div class="hero-card hero-card-2">
                <div class="card-emoji">✨</div>
                <div>Veshmbathje</div>
                <strong>Nga 19€</strong>
            </div>
            <div class="hero-card hero-card-3">
                <div class="card-emoji">✨</div>
                <div>Shtëpi & Kuzhinë</div>
                <strong>Nga 9€</strong>
            </div>
        </div>
    </div>
</section>

<!-- -- Feature Strips --------------------------------------------------- -->
<section class="feature-strip">
    <div class="feature-strip-inner">
        <div class="feature-item">
            <span class="feature-icon">✨</span>
            <div>
                <strong>Dorëzim Falas</strong>
                <p>Për porosi mbi 50€</p>
            </div>
        </div>
        <div class="feature-item">
            <span class="feature-icon">✨</span>
            <div>
                <strong>Pagim i Sigurt</strong>
                <p>SSL • Cash • Transfer</p>
            </div>
        </div>
        <div class="feature-item">
            <span class="feature-icon">✨</span>
            <div>
                <strong>Kthim 30 Ditë</strong>
                <p>Pa pyetje shtesë</p>
            </div>
        </div>
        <div class="feature-item">
            <span class="feature-icon">✨</span>
            <div>
                <strong>Mbështetje 24/7</strong>
                <p>Gjithmonë gati</p>
            </div>
        </div>
    </div>
</section>

<!-- -- Category Grid --------------------------------------------------- -->
<section class="ec-section">
    <div class="ec-container">
        <div class="section-header">
            <h2>Kategorite</h2>
            <a asp-controller="Shop" asp-action="Index">Shih të gjitha &rarr;</a>
        </div>
        <div class="category-grid">
            <a asp-controller="Shop" asp-action="Index" asp-route-q="elektronike" class="cat-card cat-blue">
                <span class="cat-icon">🏷️</span>
                <strong>Elektronikë</strong>
            </a>
            <a asp-controller="Shop" asp-action="Index" asp-route-q="elektroshtepiake" class="cat-card cat-purple">
                <span class="cat-icon">🏷️</span>
                <strong>Elektroshtepiake</strong>
            </a>
            <a asp-controller="Shop" asp-action="Index" asp-route-q="veshmbathje" class="cat-card cat-rose">
                <span class="cat-icon">🏷️</span>
                <strong>Veshmbathje</strong>
            </a>
            <a asp-controller="Shop" asp-action="Index" asp-route-q="ushqim" class="cat-card cat-green">
                <span class="cat-icon">🏷️</span>
                <strong>Ushqim & Pije</strong>
            </a>
            <a asp-controller="Shop" asp-action="Index" asp-route-q="kozmetike" class="cat-card cat-pink">
                <span class="cat-icon">🏷️</span>
                <strong>Kozmetikë</strong>
            </a>
            <a asp-controller="Shop" asp-action="Index" asp-route-q="shtepi" class="cat-card cat-orange">
                <span class="cat-icon">🏷️</span>
                <strong>Shtëpi & Kuzhinë</strong>
            </a>
            <a asp-controller="Shop" asp-action="Index" asp-route-q="sport" class="cat-card cat-teal">
                <span class="cat-icon">?</span>
                <strong>Sport</strong>
            </a>
            <a asp-controller="Shop" asp-action="Index" asp-route-q="lodra" class="cat-card cat-yellow">
                <span class="cat-icon">🏷️</span>
                <strong>Lodra & Fëmijë</strong>
            </a>
        </div>
    </div>
</section>

<!-- -- Featured Products ----------------------------------------------- -->
<section class="ec-section ec-section-alt">
    <div class="ec-container">
        <div class="section-header">
            <h2>🔥 Produkte të Rekomanduara</h2>
            <a asp-controller="Shop" asp-action="Index">Shih të gjitha &rarr;</a>
        </div>
        <div class="product-grid" id="featuredProducts">
            <div class="loading-shimmer"></div>
            <div class="loading-shimmer"></div>
            <div class="loading-shimmer"></div>
            <div class="loading-shimmer"></div>
        </div>
    </div>
</section>

<!-- -- Promo Banner ----------------------------------------------------- -->
<section class="promo-banner">
    <div class="ec-container">
        <div class="promo-inner">
            <div>
                <div class="promo-badge">? Ofertë e Kufizuar</div>
                <h2>Zbritje deri 30% në Elektronikë</h2>
                <p>Zgjidh nga shumë produkte me çmime fantastike. Oferta skadon së shpejti!</p>
                <a asp-controller="Shop" asp-action="Index" asp-route-q="elektronike" class="btn-primary-lg">
                    Shfrytëzo Ofertën
                </a>
            </div>
            <div class="promo-visual">
                <div class="promo-badge-big">-30%</div>
            </div>
        </div>
    </div>
</section>

<!-- -- New Arrivals ------------------------------------------------------ -->
<section class="ec-section">
    <div class="ec-container">
        <div class="section-header">
            <h2>? Arritjet e Reja</h2>
            <a asp-controller="Shop" asp-action="Index" asp-route-sort="newest">Shih të rejat &rarr;</a>
        </div>
        <div class="product-grid" id="newProducts">
            <div class="loading-shimmer"></div>
            <div class="loading-shimmer"></div>
            <div class="loading-shimmer"></div>
            <div class="loading-shimmer"></div>
        </div>
    </div>
</section>

<!-- -- Testimonials ---------------------------------------------------- -->
<section class="ec-section ec-section-alt">
    <div class="ec-container">
        <div class="section-header centered">
            <h2>Çfarë thonë klientët tanë</h2>
        </div>
        <div class="testimonials-grid">
            <div class="testimonial-card">
                <div class="stars">⭐⭐⭐⭐⭐</div>
                <p>"Produktet janë shumë cilësore dhe dorëzimi ishte super i shpejtë. Do të blej sërish patjetër!"</p>
                <div class="reviewer">
                    <div class="reviewer-avatar">LG</div>
                    <div><strong>Luan Gashi</strong><span>Prishtinë</span></div>
                </div>
            </div>
            <div class="testimonial-card">
                <div class="stars">⭐⭐⭐⭐⭐</div>
                <p>"Enisi Center është dyqani im i preferuar online. Çmimet janë të shkëlqyera dhe shërbimi fantastic!"</p>
                <div class="reviewer">
                    <div class="reviewer-avatar">VM</div>
                    <div><strong>Valmira Morina</strong><span>Mitrovicë</span></div>
                </div>
            </div>
            <div class="testimonial-card">
                <div class="stars">⭐⭐⭐⭐⭐</div>
                <p>"Kam blerë shumë herë dhe gjithmonë jam i kënaqur. Produktet vijnë të paketuara mirë dhe në kohë."</p>
                <div class="reviewer">
                    <div class="reviewer-avatar">AH</div>
                    <div><strong>Arben Haliti</strong><span>Ferizaj</span></div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
<script>
// Load featured products dynamically
async function loadProducts(containerId, url) {
    const container = document.getElementById(containerId);
    if (!container) return;
    try {
        const resp = await fetch(url);
        const data = await resp.json();
        if (!data.length) { container.innerHTML = '<p class="no-results">Nuk ka produkte.</p>'; return; }
        container.innerHTML = data.map(p => `
            <div class="product-card" data-id="${p.id}">
                <a href="/shop/product/${p.id}" class="product-card-link">
                    <div class="product-img-wrap">
                        <img src="${p.image || '/img/placeholder.png'}" alt="${p.name}" class="product-img" loading="lazy" />
                        ${p.isOnSale ? `<span class="badge-sale">-${p.discountPercent}%</span>` : ''}
                    </div>
                    <div class="product-info">
                        <p class="product-cat">${p.categoryName || ''}</p>
                        <h3 class="product-name">${p.name}</h3>
                        <div class="product-price-row">
                            <span class="product-price">${p.displayPrice} €</span>
                            ${p.isOnSale ? `<span class="product-old-price">${p.price} €</span>` : ''}
                        </div>
                    </div>
                </a>
                <button class="btn-add-cart" onclick="addToCart(${p.id}, this)">
                    + Shporta
                </button>
            </div>
        `).join('');
    } catch(e) {
        container.innerHTML = '<p class="no-results">Nuk mund të ngarkohen produktet.</p>';
    }
}

document.addEventListener('DOMContentLoaded', () => {
    loadProducts('featuredProducts', '/Shop/Featured');
    loadProducts('newProducts', '/Shop/Newest');
});
</script>
}
