@{
    var isSq = System.Threading.Thread.CurrentThread.CurrentUICulture.Name == "sq";
    ViewData["Title"] = isSq ? "Shërbimet" : "Services";
}

<div class="hero">
    <div class="hero-inner" style="max-width: 1200px; margin: auto; text-align: left;">
        <h1 class="hero-title" style="text-align: center;">@(isSq ? "Shërbimet Tona" : "Our Services")</h1>
        <p class="hero-sub" style="text-align: center; margin-bottom: 40px;">@(isSq ? "Zgjidhje të Përshtatura të POS" : "Tailored POS Solutions")</p>

        <div style="text-align: center; margin-bottom: 40px; font-size: 1.2em; line-height: 1.6;">
            @(isSq ? "Ne ofrojmë softuer të performancës së lartë që i ndihmon bizneset të ecin përpara me shpejtësi dhe saktësi." : "We deliver high-performance software that helps businesses move forward with speed and accuracy.")
        </div>

        <div style="display: flex; flex-wrap: wrap; gap: 40px; margin-bottom: 60px; background: rgba(0,0,0,0.4); border-radius: 8px; padding: 30px;">
            <div style="flex: 1; min-width: 300px;">
                <h3 style="color: #ff5722;">🍕 @(isSq ? "POS Për Pizzeri" : "Pizzeria POS")</h3>
                <p>@(isSq ? "Menaxhoni porositë dhe radhët e dërgesave më shpejt se kurrë. Të integruara plotësisht me sistemet e shfaqjes së kuzhinës për të optimizuar rrjedhën e punës." : "Handle orders, customized toppings, and delivery queues faster than ever. Fully integrated with kitchen display systems to optimize the workflow from prep to plate.")</p>
                <img src="~/img/kitchen-page.png" alt="Kitchen Display" style="width:100%; border-radius: 4px; border: 1px solid rgba(255,255,255,0.2); margin-top: 15px;" />
            </div>
            <div style="flex: 1; min-width: 300px;">
                <h3 style="color: #4caf50;">🛒 @(isSq ? "POS Për Supermarkete" : "Supermarket POS")</h3>
                <p>@(isSq ? "Shpejtësi e lartë e transaksioneve, skanim i barkodeve, promocione dinamike dhe menaxhim i stokut i dizajnuar për vëllime të larta të shitjes me pakicë." : "High transaction throughput, integrated barcode scanning, dynamic promotions, and heavy-duty stock management designed for high-volume retail environments.")</p>
                <img src="~/img/barcodes-page.png" alt="Barcodes & Items" style="width:100%; border-radius: 4px; border: 1px solid rgba(255,255,255,0.2); margin-top: 15px;" />
            </div>
            <div style="flex: 1; min-width: 300px;">
                <h3 style="color: #2196f3;">👕 @(isSq ? "POS Për Rroba" : "Clothing POS")</h3>
                <p>@(isSq ? "Mbani gjurmët e madhësive, ngjyrave dhe trendeve sezonale pa ndërprerje për të maksimizuar përvojën e klientit dhe saktësinë e inventarit." : "Keep track of sizes, colors, multi-location inventory, and seasonal trends seamlessly to maximize customer experience and inventory accuracy.")</p>
                <img src="~/img/articles-page.png" alt="Articles & Inventory" style="width:100%; border-radius: 4px; border: 1px solid rgba(255,255,255,0.2); margin-top: 15px;" />
            </div>
        </div>

        <h2 style="text-align: center; margin-bottom: 30px; color: #ffeb3b;">@(isSq ? "Raportim i Avancuar" : "Comprehensive Reporting")</h2>
        <div style="display: flex; flex-wrap: wrap; gap: 40px; align-items: center; justify-content: center; background: rgba(0,0,0,0.4); padding: 30px; border-radius: 8px;">
            <div style="flex: 1; min-width: 300px;">
                <img src="~/img/sales-page.png" alt="Sales Data" style="width: 100%; border-radius: 4px;" />
            </div>
            <div style="flex: 1; min-width: 300px;">
                <h4>@(isSq ? "Analitikë në Kohë Reale" : "Real-Time Analytics")</h4>
                <p>@(isSq ? "Ndiqni performancën e biznesit tuaj globalisht. Pavarësisht nëse jeni duke monitoruar shitjet ditore të një dyqani apo disa dyqaneve, ju siguroni të dhëna të menjëhershme." : "Track your business performance globally. Whether monitoring a single store's daily sales or enterprise-wide metrics, YourBrand provides instant, actionable data.")</p>
                <p>@(isSq ? "Analizoni trendet e shitjeve sipas datave, kohërave dhe produkteve specifike për të formësuar vendimet tuaja strategjike." : "Analyze sales trends across specific dates, times, and products to inform your strategic decisions.")</p>
            </div>
        </div>

        <div style="margin-top: 60px; text-align: left;">
            <h2 style="text-align: center; margin-bottom: 40px;">@(isSq ? "Shërbime të Tjera të Ofruara" : "Other Services Offered")</h2>

            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 30px;">
                <div style="background: rgba(255,255,255,0.05); padding: 25px; border-radius: 8px;">
                    <h3 style="color: #9c27b0; margin-bottom: 15px;">🌐 @(isSq ? "Dizajn dhe Zhvillim të Faqeve" : "Website Design & Development")</h3>
                    <p>@(isSq ? "Hartojmë dhe ndërtojmë web faqe funksionale dhe pamje mahnitëse për biznesin tuaj. Portofole, dyqane online (e-commerce), apo blogje – ne ofrojmë zgjidhjen e plotë për prezencën tuaj online." : "Design and build stunning, functional websites for your business. From portfolios to online stores (e-commerce) and blogs – we offer the complete solution for your online presence.")</p>
                </div>

                <div style="background: rgba(255,255,255,0.05); padding: 25px; border-radius: 8px;">
                    <h3 style="color: #e91e63; margin-bottom: 15px;">📱 @(isSq ? "Aplikacione Mobile" : "Mobile Applications")</h3>
                    <p>@(isSq ? "Zhvillojmë aplikacione moderne për pajisjet iOS dhe Android, të dizajnuara për performancë të lartë dhe përvojë të shkëlqyeshme të përdoruesit. Ne i bëjmë idetë tuaja vizuale në ekranet e telefonave." : "Develop modern applications for iOS and Android devices, designed for high performance and an excellent user experience. We bringing your visual ideas to smartphone screens.")</p>
                </div>

                <div style="background: rgba(255,255,255,0.05); padding: 25px; border-radius: 8px;">
                    <h3 style="color: #00bcd4; margin-bottom: 15px;">⚙️ @(isSq ? "Sisteme të Personalizuara" : "Custom Systems")</h3>
                    <p>@(isSq ? "Biznesi juaj ka nevoja unike? Ekipi ynë mundëson zhvillimin e softuerëve të ndërtuar për qëllime specifike (p.sh. ERP, CRM), krejtësisht të përshtatshme me proceset tuaja operative." : "Does your business have unique needs? Our team can develop purpose-built software (e.g., ERP, CRM) fully tailored to your operational processes.")</p>
                </div>
            </div>
        </div>
    </div>
</div>

